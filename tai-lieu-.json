      {
        "parameters": {
          "promptType": "define",
          "text": "=Bạn là AI phân loại yêu cầu về tài liệu.\n\nInput:\n{{ $json.ChatInput }}\n\nPhân loại câu hỏi vào 1 trong 3 case:\n\n1 = Tổng quan tài liệu (câu hỏi chung)\n2 = Tổng quan tài liệu của một đơn vị\n3 = Xem chi tiết một tài liệu cụ thể\n\nQuy tắc:\n\nCase 3:\n- Nếu câu hỏi có tên file, mã tài liệu, hoặc đuôi file như .pdf, .doc, .docx, .xls, .xlsx\n- Ví dụ: \"xem tài liệu ABC.pdf\"\n\nCase 2:\n- Nếu câu hỏi có nhắc đến đơn vị như MDV, LDV hoặc có cụm \"đơn vị\"\n\nCase 1:\n- Các câu hỏi còn lại về tài liệu chung như:\n  \"tài liệu\"\n  \"xem tài liệu\"\n  \"tổng quan tài liệu\"\n  \"thống kê tài liệu\"\n\nChỉ trả về đúng JSON, không giải thích:\n\n{\n  \"case\": \"number\",\n  \"query\": \"{{ $json.ChatInput }}\"\n}",
          "hasOutputParser": true,
          "options": {
            "systemMessage": "=xem tài liệu 5_THTB_ANVT_signed_27.pdf"
          }
        },
        "type": "@n8n/n8n-nodes-langchain.agent",
        "typeVersion": 1.9,
        "position": [
          -816,
          480
        ],
        "id": "509777d5-520d-473e-b1b9-8f373591d390",
        "name": "AI Agent26",
        "alwaysOutputData": true,
        "retryOnFail": true,
        "maxTries": 5,
        "waitBetweenTries": 1000,
        "executeOnce": false,
        "notesInFlow": true
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all().map(i => i.json);\n\nlet tongTaiLieu = 0;\nlet donVi = \"\";\nlet danhSach = [];\n\nfor (const item of items) {\n\n  if (item[\"tong_so_tai_lieu\"] && !item[\"ma_tai_lieu\"]) {\n    tongTaiLieu = item[\"tong_so_tai_lieu\"];\n  }\n\n  if (item[\"don_vi\"] && item[\"don_vi\"] !== \"\") {\n    donVi = item[\"don_vi\"];\n  }\n\n  if (item[\"ma_tai_lieu\"]) {\n    danhSach.push(item);\n  }\n}\n\n// nếu đơn vị = * thì đổi thành \"chung\"\nif (donVi === \"*\") {\n  donVi = \"chung\";\n}\n\nlet answer = `- **Tổng số tài liệu của đơn vị ${donVi || \"toàn hệ thống\"}:** ${tongTaiLieu}\\n\\n`;\n\nanswer += `- **Một số tài liệu trong hệ thống:**\\n`;\n\ndanhSach.slice(0,5).forEach(tl => {\n  answer += `+ ${tl.ten_tai_lieu} (Mã: ${tl.ma_tai_lieu})\\n`;\n});\n\nconst suggestions = [];\n\n// đề xuất tổng quan theo đơn vị\nif (donVi) {\n  suggestions.push(`tổng quan tài liệu của đơn vị ${donVi}`);\n}\n\n// đề xuất mở tài liệu\ndanhSach.slice(0,2).forEach(tl => {\n  suggestions.push(`xem tài liệu ${tl.ten_tai_lieu}`);\n});\n\nreturn [\n{\n  json: {\n    answer: answer.trim(),\n    suggestions\n  }\n}\n];"
        },
