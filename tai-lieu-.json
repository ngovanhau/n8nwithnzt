          "query": "SELECT COUNT(*) AS tong_so_tai_lieu\nFROM R5DOCUMENTS;\n\nSELECT \n    d.DOC_ORG AS don_vi,\n    COUNT(*) AS so_tai_lieu\nFROM R5DOCUMENTS AS d\nGROUP BY d.DOC_ORG\nORDER BY so_tai_lieu DESC;\n\nselect top 5 \nDOC_CODE as ma_tai_lieu,\nDOC_DESC as ten_tai_lieu,\nDOC_ORG as don_vi\nfrom R5DOCUMENTS \norder by DOC_CREATED desc\n"
