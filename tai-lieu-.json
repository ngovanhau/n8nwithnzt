          "jsCode": "const items = $input.all().map(i => i.json);\n\nlet donVi = \"\";\nlet soTaiLieu = 0;\nlet taiLieu = [];\n\nfor (const item of items) {\n\n  // record tổng\n  if (item.so_tai_lieu && !item.ma_tai_lieu) {\n    soTaiLieu = item.so_tai_lieu;\n  }\n\n  // đơn vị\n  if (item.don_vi !== undefined) {\n    donVi = item.don_vi;\n  }\n\n  // danh sách tài liệu\n  if (item.ma_tai_lieu) {\n    taiLieu.push(item);\n  }\n}\n\n// nếu đơn vị là * thì đổi thành chung\nif (donVi === \"*\") {\n  donVi = \"chung\";\n}\n\nlet answer = `- **Đơn vị:** ${donVi}\\n\\n`;\nanswer += `+ Số tài liệu: ${soTaiLieu}\\n`;\n\n// suggestions\nlet suggestions = [];\n\ntaiLieu.slice(0,2).forEach(tl => {\n  suggestions.push(`Xem tài liệu ${tl.ten_tai_lieu}`);\n});\n\nreturn [\n{\n  json: {\n    output: {\n      answer: answer.trim(),\n      suggestions\n    }\n  }\n}\n];"
